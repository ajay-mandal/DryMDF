# =============================================================================
# DryMDF Docker Build Context Ignore File
# =============================================================================

# Dependencies - installed in container
node_modules
**/node_modules

# Build outputs - built in container
dist
**/dist
.next
**/.next
.turbo
**/.turbo

# Development files
.git
.gitignore
.github
.vscode
.idea

# Documentation
*.md
!README.md
docs/
CHANGELOG.md
CONTRIBUTING.md
LICENSE

# Test files
**/*.test.ts
**/*.spec.ts
**/test/
**/tests/
coverage/
**/coverage/
jest.config.*
**/*.e2e-spec.ts

# Environment files (secrets)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml

# Turbo prune output (created locally, not needed in context)
out/

# IDE and OS files
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Cache
.cache
**/.cache
.eslintcache
.prettiercache

# TypeScript cache
*.tsbuildinfo

# Deployment files
deployment/
scripts/
*.sh

# Vercel
.vercel

# Misc
*.tgz
*.tar.gz
*.zip
